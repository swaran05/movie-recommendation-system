safe_json <- function(x){
x <- gsub("'", '"', x)   # fix single quotes if present
tryCatch({
data <- jsonlite::fromJSON(x)
paste(data$name, collapse = " ")
}, error = function(e) {
NA
})
}
tmdb_movies$genres <- sapply(tmdb_movies$genres, safe_json)
tmdb_movies$keywords <- sapply(tmdb_movies$keywords, safe_json)
safe_cast <- function(x){
tryCatch({
data <- jsonlite::fromJSON(x)
paste(head(data$name, 3), collapse = " ")
}, error = function(e){
NA
})
}
credits$cast <- sapply(credits$cast, safe_cast)
tmdb_movies <- merge(tmdb_movies, credits[, .(title, cast)], by="title")
