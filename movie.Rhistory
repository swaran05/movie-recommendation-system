tmdb_movies <- fread("tmdb_5000_movies.csv")
credits     <- fread("tmdb_5000_credits.csv")
library(jsonlite)
extract_names <- function(x){
x <- gsub("'", '"', x)
x <- gsub('""', '"', x)
tryCatch({
data <- fromJSON(x)
paste(data$name, collapse=" ")
}, error=function(e){
""
})
}
tmdb_movies$genres   <- sapply(tmdb_movies$genres, extract_names)
tmdb_movies$keywords <- sapply(tmdb_movies$keywords, extract_names)
extract_cast <- function(x){
x <- gsub("'", '"', x)
x <- gsub('""', '"', x)
tryCatch({
data <- fromJSON(x)
paste(head(data$name,3), collapse=" ")
}, error=function(e){
""
})
}
credits$cast <- sapply(credits$cast, extract_cast)
tmdb_movies$cast <- credits$cast[
match(tmdb_movies$title, credits$title)
]
head(tmdb_movies$genres, 5)
head(tmdb_movies$cast, 5)
clean_title <- function(x){
x <- tolower(x)
x <- gsub("[^a-z0-9 ]", "", x)  # remove punctuation
x <- gsub("\\s+", " ", x)       # remove extra spaces
trimws(x)
}
tmdb_movies$clean_title <- clean_title(tmdb_movies$title)
credits$clean_title     <- clean_title(credits$title)
tmdb_movies$cast <- credits$cast[
match(tmdb_movies$clean_title, credits$clean_title)
]
head(tmdb_movies$cast, 10)
table(tmdb_movies$cast == "")
library(stringr)
tmdb_movies$overview <- word(tmdb_movies$overview, 1, 30)
tmdb_movies$overview[is.na(tmdb_movies$overview)] <- ""
tmdb_movies$content <- paste(
paste(tmdb_movies$genres, tmdb_movies$genres, tmdb_movies$genres),   # x3
paste(tmdb_movies$keywords, tmdb_movies$keywords),                   # x2
tmdb_movies$overview                                                  # x1
)
library(tm)
corpus <- VCorpus(VectorSource(tmdb_movies$content))
corpus <- tm_map(corpus, content_transformer(tolower))
corpus <- tm_map(corpus, removePunctuation)
corpus <- tm_map(corpus, removeNumbers)
corpus <- tm_map(corpus, removeWords, stopwords("en"))
corpus <- tm_map(corpus, stripWhitespace)
dtm <- DocumentTermMatrix(corpus)
dtm <- removeSparseTerms(dtm, 0.99)
dtm_matrix <- as.matrix(dtm)
library(proxy)
similarity <- as.matrix(simil(dtm_matrix, method="cosine"))
recommend_movie <- function(name){
idx <- which(tmdb_movies$title == name)
if(length(idx)==0) return("Movie not found")
top <- order(similarity[idx,], decreasing=TRUE)[2:6]
tmdb_movies$title[top]
}
