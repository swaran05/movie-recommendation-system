clean_title <- function(x){
x <- tolower(x)
x <- gsub("[^a-z0-9 ]", "", x)
x <- gsub("\\s+", " ", x)
trimws(x)
}
tmdb_movies$clean_title <- clean_title(tmdb_movies$title)
recommend_movie <- function(name){
name_clean <- clean_title(name)
idx <- grep(name_clean, tmdb_movies$clean_title)
if(length(idx)==0){
return("Movie not found")
}
idx <- idx[1]   # take best match
top <- order(similarity[idx,], decreasing=TRUE)[2:6]
tmdb_movies$title[top]
}
recommend_movie("fast furious")
recommend_movie <- function(name){
name_clean <- clean_title(name)
words <- unlist(strsplit(name_clean, " "))
# find titles containing ALL words
idx <- which(sapply(tmdb_movies$clean_title, function(title){
all(words %in% unlist(strsplit(title, " ")))
}))
if(length(idx)==0){
return("Movie not found")
}
idx <- idx[1]  # best match
top <- order(similarity[idx,], decreasing=TRUE)[2:6]
tmdb_movies$title[top]
}
recommend_movie("fast furious")
recommend_movie("inception")
recommend_movie("ford v ferrai")
install.packages("stringdist")
library(stringdist)
recommend_movie <- function(name){
name_clean <- clean_title(name)
# compute string distance to all titles
distances <- stringdist(name_clean, tmdb_movies$clean_title, method="jw")
idx <- which.min(distances)  # closest title
if(distances[idx] > 0.25){   # threshold (lower = stricter)
return("Movie not found")
}
top <- order(similarity[idx,], decreasing=TRUE)[2:6]
tmdb_movies$title[top]
}
recommend_movie("ford v ferrai")
recommend_movie <- function(name){
name_clean <- clean_title(name)
distances <- stringdist(name_clean, tmdb_movies$clean_title, method="jw")
idx <- which.min(distances)
# more tolerant threshold
if(distances[idx] > 0.35){
return("Movie not found")
}
cat("Matched with:", tmdb_movies$title[idx], "\n\n")
top <- order(similarity[idx,], decreasing=TRUE)[2:6]
tmdb_movies$title[top]
}
recommend_movie("ford v ferrai")
recommend_movie("inception")
library(stringdist)
recommend_movie <- function(name){
name_clean <- clean_title(name)
query_words <- unlist(strsplit(name_clean, " "))
# 1️⃣ Title word overlap score
overlap_score <- sapply(tmdb_movies$clean_title, function(title){
title_words <- unlist(strsplit(title, " "))
sum(query_words %in% title_words)
})
# 2️⃣ String similarity (typo handling)
jw_dist <- stringdist(name_clean, tmdb_movies$clean_title, method="jw")
# 3️⃣ Combine both scores
final_score <- overlap_score - jw_dist   # higher is better
idx <- which.max(final_score)
# if still weak match
if(overlap_score[idx] == 0 && jw_dist[idx] > 0.4){
return("Movie not found")
}
cat("Matched with:", tmdb_movies$title[idx], "\n\n")
top <- order(similarity[idx,], decreasing=TRUE)[2:6]
tmdb_movies$title[top]
}
recommend_movie("ford v ferrai")
recommend_movie("fast furious")
recommend_movie("spider man")
recommend_movie("dark knight rises")
recommend_movie("avatr")
library(stringdist)
recommend_movie <- function(name){
name_clean <- clean_title(name)
query_words <- unlist(strsplit(name_clean, " "))
# remove short useless words like "v", "a", "an", "of"
query_words <- query_words[nchar(query_words) >= 3]
# 1️⃣ Word overlap score
overlap_score <- sapply(tmdb_movies$clean_title, function(title){
title_words <- unlist(strsplit(title, " "))
title_words <- title_words[nchar(title_words) >= 3]
sum(query_words %in% title_words)
})
# 2️⃣ Fuzzy string similarity
jw_dist <- stringdist(name_clean, tmdb_movies$clean_title, method="jw")
# 3️⃣ Combined ranking
final_score <- overlap_score * 2 - jw_dist   # overlap more important
idx <- which.max(final_score)
# If still weak
if(overlap_score[idx] == 0 && jw_dist[idx] > 0.35){
return("Movie not found")
}
cat("Matched with:", tmdb_movies$title[idx], "\n\n")
top <- order(similarity[idx,], decreasing=TRUE)[2:6]
tmdb_movies$title[top]
}
recommend_movie("ford v ferrai")
recommend_movie("fast furious")
recommend_movie("spider man")
recommend_movie("dark knight rises")
recommend_movie("avatr")
recommend_movie("avatr")
recommend_movie("dark knight rises")
recommend_movie("dark knight rises")
recommend_movie("fast furious")
recommend_movie("fast furious")
