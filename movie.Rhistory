paste(g$name, collapse = " ")
})
clean_json <- function(x) {
x <- gsub('""', '"', x)     # fix double quotes
x <- gsub("\\\\", "", x)    # remove slashes
fromJSON(x)
}
tmdb_movies$genres <- sapply(tmdb_movies$genres, function(x) {
g <- clean_json(x)
paste(g$name, collapse = " ")
})
tmdb_movies$keywords <- sapply(tmdb_movies$keywords, function(x) {
k <- clean_json(x)
paste(k$name, collapse = " ")
})
clean_json <- function(x) {
x <- gsub('""', '"', x)             # fix double quotes
x <- gsub("\\\\", "", x)            # remove slashes
x <- gsub('\"([a-zA-Z ]+)\"', '\\1', x)  # remove inner quotes inside names
tryCatch({
fromJSON(x)
}, error = function(e) {
data.frame(name = NA)   # if still broken, return NA instead of stopping
})
}
tmdb_movies$genres <- sapply(tmdb_movies$genres, function(x) {
g <- clean_json(x)
paste(g$name, collapse = " ")
})
tmdb_movies$keywords <- sapply(tmdb_movies$keywords, function(x) {
k <- clean_json(x)
paste(k$name, collapse = " ")
})
credits$cast <- sapply(credits$cast, function(x) {
c <- clean_json(x)
paste(head(c$name, 3), collapse = " ")
})
tmdb_movies <- merge(tmdb_movies, credits[, .(title, cast)], by="title")
tmdb_movies$overview[is.na(tmdb_movies$overview)] <- ""
tmdb_movies$content <- paste(
tmdb_movies$genres,
tmdb_movies$keywords,
tmdb_movies$cast,
tmdb_movies$overview
)
corpus <- VCorpus(VectorSource(tmdb_movies$content))
corpus <- tm_map(corpus, content_transformer(tolower))   # lowercase
corpus <- tm_map(corpus, removePunctuation)              # remove symbols
corpus <- tm_map(corpus, removeNumbers)                  # remove numbers
corpus <- tm_map(corpus, removeWords, stopwords("en"))   # remove common words
corpus <- tm_map(corpus, stripWhitespace)                # remove extra spaces
dtm <- DocumentTermMatrix(corpus)
dtm_matrix <- as.matrix(dtm)
similarity <- 1 - as.matrix(dist(dtm_matrix, method = "cosine"))
similarity <- 1 - as.matrix(dist(dtm_matrix, method = "cosine"))
library(proxy)
similarity <- as.matrix(simil(dtm_matrix, method = "cosine"))
rm(similarity)
dtm <- removeSparseTerms(dtm, 0.98)
dtm_matrix <- as.matrix(dtm)
object.size(dtm_matrix)
library(proxy)
similarity <- as.matrix(simil(dtm_matrix, method = "cosine"))
recommend_movie <- function(movie_name) {
idx <- which(tmdb_movies$title == movie_name)
if(length(idx) == 0){
return("Movie not found")
}
sim_scores <- similarity[idx, ]
sim_scores <- sort(sim_scores, decreasing = TRUE)
top_idx <- as.numeric(names(sim_scores))[2:6]
return(tmdb_movies$title[top_idx])
}
